PORT=5001
NODE_ENV=development
BACKEND_URL=http://localhost:5001
FRONTEND_URL=http://localhost:3000
MONGODB_URI=mongodb://127.0.0.1:27017/smartbank
DB_CONNECT_TIMEOUT_MS=10000
DB_MAX_POOL_SIZE=20
SHUTDOWN_TIMEOUT_MS=10000

# Google OAuth
# Authorized redirect URI in Google Cloud Console:
# http://localhost:5001/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5001/api/auth/google/callback

JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_REFRESH_EXPIRE=30d
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_ACCESS_EXPIRE=15m

# Initial superadmin bootstrap account.
# This account is created only when no superadmin exists yet.
SUPERADMIN_FIRST_NAME=System
SUPERADMIN_LAST_NAME=Owner
SUPERADMIN_EMAIL=owner@smartbank.local
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
SUPERADMIN_PHONE=+94000000000
SUPERADMIN_ADDRESS=Head Office

# Set to true only if you intentionally want local demo users created.
ENABLE_DEMO_USERS=false
TRUST_PROXY_HOPS=0
ENCRYPTION_KEY=replace-with-at-least-32-random-characters

# Optional email delivery
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional authenticated document mirror
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

MAX_FILE_SIZE=5242880
